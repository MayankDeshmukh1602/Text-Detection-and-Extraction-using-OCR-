{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index1.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(register|login)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index1.html"
    }
  ]
}
